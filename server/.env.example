# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=restaurante_pedidos_gigantya

# Servidor
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=tu_clave_secreta_super_segura_aqui_123456789
JWT_EXPIRE=7d

# Login con Google (Google Identity Services)
# Client ID de OAuth 2.0 tipo "Aplicación web" (Google Cloud Console).
# Es el MISMO valor que VITE_GOOGLE_CLIENT_ID en el .env del cliente.
# Solo hace falta el Client ID (no el secret) porque validamos el ID token.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Socket.IO
SOCKET_PORT=5001

# CORS
CORS_ORIGIN=https://gigantya.com

# URL pública del frontend (usada para construir enlaces en emails, ej: reset password)
# - Desarrollo:  http://localhost:5173
# - Producción:  https://gigantya.com
FRONTEND_URL=https://gigantya.com

# ====================================================
# NOTIFICACIONES EXTERNAS (Email/SMS)
# ====================================================
# Dejar EMAIL_ENABLED=false y WHATSAPP_ENABLED=false para usar solo notificaciones internas

# Email (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM=GigantYA <noreply@gigantya.com>

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=tu_business_account_id
WHATSAPP_API_TOKEN=tu_access_token
WHATSAPP_API_VERSION=v20.0
WHATSAPP_LANGUAGE_CODE=es

# ====================================================
# EJEMPLO SENDGRID (opcional)
# ====================================================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=tu_api_key_de_sendgrid

