# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=restaurante_pedidos_gigantya

# Servidor
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=tu_clave_secreta_super_segura_aqui_123456789
JWT_EXPIRE=7d

# Socket.IO
SOCKET_PORT=5001

# CORS
CORS_ORIGIN=http://localhost:5173

# ====================================================
# NOTIFICACIONES EXTERNAS (Email/SMS)
# ====================================================
# Dejar EMAIL_ENABLED=false y SMS_ENABLED=false para usar solo notificaciones internas

# Email (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM=GigantYA <noreply@gigantya.com>

# SMS (Twilio)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=tu_account_sid
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_PHONE_NUMBER=+1234567890

