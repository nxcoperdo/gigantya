# API Configuration
VITE_API_URL=http://localhost:5000/api

# Socket.IO Configuration
VITE_SOCKET_URL=http://localhost:5000

# Google Maps JS API: ya no se usa en el cliente. La única integración con
# Google Maps es el iframe de embed público en AddressMapPreview.jsx, que no
# requiere API key. Si en el futuro se quiere usar Places Autocomplete o Maps
# JS, volver a agregar VITE_GOOGLE_MAPS_API_KEY y configurar la whitelist de
# referrers en Google Cloud Console.